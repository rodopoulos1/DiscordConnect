# Token do seu bot Discord
DISCORD_TOKEN=seu_token_aqui

# ID do canal onde o painel será enviado
CANAL_ID=123456789012345678

# ID do servidor (guild) autorizado — o bot vai sair de qualquer outro servidor automaticamente
# Deixe vazio para desativar a restrição
GUILD_ID=123456789012345678

# Endereço do servidor de jogo
SERVER_IP=127.0.0.1
SERVER_PORT=27015

# Jogo — usado para escolher a imagem automática
# Valores reconhecidos: cs2, csgo, tf2, gmod, rust, ark
# Qualquer outro valor exibirá o nome como label sem imagem automática
GAME=cs2

# Nome exibido quando o servidor estiver offline
SERVER_NOME_PADRAO=Meu Servidor

# (Opcional) URL de imagem fixa — sobrescreve a seleção automática por jogo/mapa
ICONE_URL=

# URL da página connect.html hospedada no GitHub Pages
# O bot vai gerar o link como: CONNECT_PAGE_URL?ip=...&port=...
# Se deixar vazio, o botão usará o protocolo steam:// diretamente
CONNECT_PAGE_URL=https://seuusuario.github.io/DiscordConnect/connect.html

# Intervalo entre atualizações do painel, em segundos (padrão: 300)
INTERVALO_ATUALIZACAO=300

# Personalização do painel
EMBED_TITULO=🌐 Status
EMBED_FOOTER=Discord Connect ▹ by Rodopoulos
BOTAO_LABEL=🎮 Conectar-se

# Campos a exibir no embed (true/false)
EXIBIR_JOGO=true
EXIBIR_JOGADORES=true
EXIBIR_MAPA=true
